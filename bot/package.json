{
  "name": "bot",
  "version": "1.0.0",
  "description": "A-Meet Discord bot — thin discord.js adapter over the /api/integrations/discord API",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "register": "tsx src/register-commands.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@a-meet/contracts": "file:../shared",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  }
}
