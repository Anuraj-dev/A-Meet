# Replace YOUR_DOMAIN / YOUR_PUBLIC_IP and set TURN_SECRET in server/.env before deploying.
listening-port=3478
tls-listening-port=5349
realm=YOUR_DOMAIN
server-name=YOUR_DOMAIN

# CRITICAL on cloud hosts behind 1:1 NAT (AWS EC2, GCP, etc.): coturn binds the
# instance's PRIVATE interface, so without this it advertises relay candidates
# using the private IP — unreachable from the internet, and the relay silently
# fails. Advertise the PUBLIC IP instead. For 1:1 NAT use the PUBLIC/PRIVATE
# form so coturn maps the advertised public address to the local private one:
#   external-ip=13.49.185.86/172.31.22.215
external-ip=YOUR_PUBLIC_IP

# Constrain the relay port range so only a small UDP band must be opened in the
# cloud firewall / security group (coturn's default is 49152–65535).
min-port=49160
max-port=49200

# Long-term credential mechanism. username=ameet, password=TURN_SECRET from .env.
lt-cred-mech
user=ameet:TURN_SECRET_PLACEHOLDER

fingerprint
no-multicast-peers

# Block private IP ranges to prevent TURN from being used as a proxy into the
# server's internal network.
denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255

# Log to stdout so `docker logs ameet-coturn-1` works (the container has no
# writable /var/log, which silently broke file logging).
log-file=stdout
