VITE_SERVER_URL=http://localhost:5000

# TURN relay credentials — fill in for LAN/prod testing (matches server/.env)
VITE_TURN_DOMAIN=
VITE_TURN_USERNAME=ameet
VITE_TURN_SECRET=

# Debug: set to 1 (with TURN configured) to force ALL media through the coturn
# relay, to verify the relay path end-to-end. Leave empty for normal operation.
VITE_FORCE_RELAY=
