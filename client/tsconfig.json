{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client", "@testing-library/jest-dom"]
  },
  // Leaf-up migration: only migrated TypeScript modules are type-checked, added
  // file-by-file as they convert. JavaScript keeps building untouched via Vite.
  // As `src/` finishes migrating, this can collapse to a "src" glob.
  "include": [
    "typecheck",
    "src/components/BrandMark.tsx",
    "src/components/EtherealShadow.tsx",
    "src/components/LiveCaptions.tsx",
    "src/components/ReactionsOverlay.tsx",
    "src/components/RemoteAudio.tsx",
    "src/components/RtcStatsOverlay.tsx",
    "src/utils/capture-screenshot.ts",
    "src/utils/peer-color.ts",
    "src/utils/room-entry.ts",
    "src/utils/transcript.ts",
    "src/utils/video-composite.ts",
    "src/utils/pending-producers.ts",
    "src/utils/calendar-invite.ts",
    "src/utils/format-time.ts",
    "src/utils/logger.ts",
    "src/utils/logger.test.ts",
    "src/api/axios.ts",
    "src/api/meetings.ts",
    "src/services/socket.ts",
    "src/services/mediasoup-signal.ts",
    "src/services/ice-config.ts",
    "src/services/sounds.ts",
    "src/services/webrtc.ts",
    "src/hooks/useMediasoup.ts",
    "src/hooks/useMediasoup.test.tsx",
    "src/hooks/useWebRTC.ts",
    "src/hooks/useScreenShare.ts",
    "src/hooks/useScreenShare.test.tsx",
    "src/hooks/usePcmCapture.ts",
    "src/hooks/usePcmCapture.test.tsx",
    "src/hooks/useHostModeration.ts",
    "src/hooks/useHostModeration.test.tsx",
    "src/hooks/useRoomLayout.ts",
    "src/hooks/useRoomLayout.test.tsx",
    "src/hooks/useReactions.ts",
    "src/hooks/useReactions.test.ts",
    "src/hooks/useLobbyMedia.ts",
    "src/hooks/usePictureInPicture.ts",
    "src/hooks/useAudioLevel.ts",
    "src/App.tsx",
    "src/main.tsx",
    "src/context/AuthContext.tsx",
    "src/components/CallNotifications.tsx",
    "src/components/ErrorBoundary.tsx",
    "src/components/ProtectedRoute.tsx",
    "src/components/RoomGuard.tsx",
    "src/components/RoomGuard.test.tsx",
    "src/components/SpaceCanvas.tsx",
    "src/components/TranscriptPanel.tsx",
    "src/components/BrandMark.test.tsx",
    "src/components/ChatPanel.tsx",
    "src/components/ChatPanel.test.tsx",
    "src/components/ControlBar.tsx",
    "src/components/ControlBar.test.tsx",
    "src/components/PeoplePanel.tsx",
    "src/components/PeoplePanel.test.tsx",
    "src/components/ScheduleMeetingDialog.tsx",
    "src/components/UpcomingMeetings.tsx",
    "src/components/VideoTile.tsx",
    "src/components/VideoTile.test.tsx",
    "src/pages/CheckMeetingCode.tsx",
    "src/pages/LandingPage.tsx",
    "src/pages/LobbyPage.tsx",
    "src/pages/LobbyPage.test.tsx",
    "src/pages/RoomPage.tsx",
    "src/theme/theme.ts"
  ]
}
