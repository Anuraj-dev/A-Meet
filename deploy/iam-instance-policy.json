{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadRuntimeParameters",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath"
      ],
      "Resource": [
        "arn:aws:ssm:*:*:parameter/a-meet/prod/server",
        "arn:aws:ssm:*:*:parameter/a-meet/prod/server/*"
      ]
    },
    {
      "Sid": "WriteContainerLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:log-group:/a-meet/prod/server:*"
    }
  ]
}
