{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadTelegramParameters",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameters"
      ],
      "Resource": [
        "arn:aws:ssm:*:*:parameter/a-meet/prod/telegram/token",
        "arn:aws:ssm:*:*:parameter/a-meet/prod/telegram/chat-id"
      ]
    },
    {
      "Sid": "LambdaLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
