# ── Server config (copy to server/.env and fill) ──────────────────────────
PORT=5000
NODE_ENV=development

# Production only: docker-compose.prod.yml sets this to an SSM path and the
# image entrypoint loads/decrypts its parameters before the app starts.
# Local development leaves it unset and continues to use this .env file.
# SSM_PARAMETER_PREFIX=/a-meet/prod/server

CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# MongoDB connection.
#   • Local dev  → the Docker Mongo container. Credentials here MUST match
#                  MONGO_ROOT_USERNAME/PASSWORD in the repo-root .env (Compose reads those).
#   • Production → a MongoDB Atlas SRV string; no Mongo container runs on the prod node.
#                  e.g. mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/ameet?retryWrites=true&w=majority
#                  (allowlist the prod node's public IP in Atlas → Network Access). See README "Deployment".
MONGO_URI=mongodb://admin:change-me@localhost:27017/ameet?authSource=admin

# JWT signing secret — use a long random string
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Google OAuth credentials from Google Cloud Console
# Authorized redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── TURN server (M6) ──────────────────────────────────────────────────────
# coturn credentials — must match coturn/turnserver.conf user line.
TURN_SECRET=change-me-to-a-long-random-turn-secret
TURN_USERNAME=ameet
TURN_DOMAIN=your-domain.example.com

# ── mediasoup SFU (M4) ─────────────────────────────────────────────────────
# IP the server ADVERTISES to browsers for media (they send RTP here). It must be
# an address the client can route to — NOT the machine's private NIC address.
#   • 127.0.0.1        → same-machine multi-tab only (local dev)
#   • LAN testing      → your host's LAN IP, e.g. 192.168.x.x
#   • Cloud/EC2 prod   → the instance's PUBLIC IP (the private 172.31.x.x NIC
#                        address will NOT work — remote peers can't reach it).
# On EC2 you can leave this blank/loopback: the server auto-detects the public
# IPv4 via the instance metadata service at startup (logged). Setting it
# explicitly is still recommended (skips the lookup, survives non-EC2 hosts).
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
# UDP/TCP port range mediasoup uses for RTC. Open these in the firewall for LAN/prod.
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
# Worker pool size. Empty = one per CPU core.
MEDIASOUP_NUM_WORKERS=

# ── Shared transcription (M11) ─────────────────────────────────────────────
# Deepgram Nova-3 provides low-latency interim/final captions. Groq Whisper
# independently refines completed turns for jargon and word accuracy.
DEEPGRAM_API_KEY=
GROQ_API_KEY=
DEEPGRAM_TRANSCRIPTION_MODEL=nova-3
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_TRANSCRIPT_MERGE_MODEL=llama-3.3-70b-versatile

# ── Rate limiting (issue #161) ─────────────────────────────────────────────
# All optional — the baked-in defaults below are generous enough that a normal
# meeting participant never hits them. See docs/conventions.md for the rationale.
# HTTP: per-IP fixed windows (express-rate-limit, in-memory).
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=60
RATE_LIMIT_ROOM_WINDOW_MS=60000
RATE_LIMIT_ROOM_MAX=100
# Sockets: per-connection token buckets (capacity = burst, refill = sustained/s).
RATE_LIMIT_SOCKET_SIGNALING_CAPACITY=300
RATE_LIMIT_SOCKET_SIGNALING_REFILL=100
RATE_LIMIT_SOCKET_CHAT_CAPACITY=20
RATE_LIMIT_SOCKET_CHAT_REFILL=5
# Consecutive denials on one socket before it is force-disconnected.
RATE_LIMIT_SOCKET_FLOOD_DISCONNECT=100
