# ── Server config (copy to server/.env and fill) ──────────────────────────
PORT=5000
NODE_ENV=development

CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# MongoDB connection (matches root docker-compose creds; authSource=admin)
MONGO_URI=mongodb://admin:change-me@localhost:27017/ameet?authSource=admin

# JWT signing secret — use a long random string
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Google OAuth credentials from Google Cloud Console
# Authorized redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── TURN server (M6) ──────────────────────────────────────────────────────
# coturn credentials — must match coturn/turnserver.conf user line.
TURN_SECRET=change-me-to-a-long-random-turn-secret
TURN_USERNAME=ameet
TURN_DOMAIN=your-domain.example.com

# ── mediasoup SFU (M4) ─────────────────────────────────────────────────────
# IP the server ADVERTISES to browsers for media (they send RTP here). It must be
# an address the client can route to — NOT the machine's private NIC address.
#   • 127.0.0.1        → same-machine multi-tab only (local dev)
#   • LAN testing      → your host's LAN IP, e.g. 192.168.x.x
#   • Cloud/EC2 prod   → the instance's PUBLIC IP (the private 172.31.x.x NIC
#                        address will NOT work — remote peers can't reach it).
# On EC2 you can leave this blank/loopback: the server auto-detects the public
# IPv4 via the instance metadata service at startup (logged). Setting it
# explicitly is still recommended (skips the lookup, survives non-EC2 hosts).
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
# UDP/TCP port range mediasoup uses for RTC. Open these in the firewall for LAN/prod.
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100
# Worker pool size. Empty = one per CPU core.
MEDIASOUP_NUM_WORKERS=

# ── Shared transcription (M11) ─────────────────────────────────────────────
# Deepgram Nova-3 provides low-latency interim/final captions. Groq Whisper
# independently refines completed turns for jargon and word accuracy.
DEEPGRAM_API_KEY=
GROQ_API_KEY=
DEEPGRAM_TRANSCRIPTION_MODEL=nova-3
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_TRANSCRIPT_MERGE_MODEL=llama-3.3-70b-versatile
